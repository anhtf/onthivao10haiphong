// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum UserType {
  STUDENT
  TEACHER
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SessionStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         Role      @default(STUDENT)
  userType     UserType  @default(STUDENT) @map("user_type")
  isPro        Boolean   @default(false) @map("is_pro")
  dateOfBirth  DateTime? @map("date_of_birth") // Học sinh: bắt buộc; Giáo viên: không bắt buộc
  hometown     String?   // Học sinh: bắt buộc; Giáo viên: không bắt buộc
  schoolName   String?   @map("school_name") // Trường đang học / đang công tác
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  exams    Exam[]
  sessions ExamSession[]
  results  Result[]

  @@map("users")
}

model Exam {
  id               String     @id @default(uuid())
  title            String
  subject          String     @default("Tổng hợp")
  description      String?
  timeLimitMinutes Int        @map("time_limit_minutes")
  totalQuestions   Int        @default(0) @map("total_questions")
  status           ExamStatus @default(DRAFT)
  pdfFilePath      String?    @map("pdf_file_path")
  expiresAt        DateTime?  @map("expires_at")
  createdBy        String     @map("created_by")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  creator   User          @relation(fields: [createdBy], references: [id])
  questions Question[]
  sessions  ExamSession[]
  results   Result[]

  @@map("exams")
}

model Question {
  id             String   @id @default(uuid())
  examId         String   @map("exam_id")
  questionNumber Int      @map("question_number")
  content        String?
  imageUrl       String?  @map("image_url")
  optionA        String?  @map("option_a")
  optionB        String?  @map("option_b")
  optionC        String?  @map("option_c")
  optionD        String?  @map("option_d")
  correctAnswer  String?  @map("correct_answer") // "A" | "B" | "C" | "D"
  explanation    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]

  @@unique([examId, questionNumber])
  @@map("questions")
}

model ExamSession {
  id               String        @id @default(uuid())
  studentId        String        @map("student_id")
  examId           String        @map("exam_id")
  questionOrder    String[]      @map("question_order") // Randomized question IDs
  startedAt        DateTime      @default(now()) @map("started_at")
  submittedAt      DateTime?     @map("submitted_at")
  timeTakenSeconds Int?          @map("time_taken_seconds")
  score            Int?
  totalQuestions   Int           @map("total_questions")
  status           SessionStatus @default(IN_PROGRESS)
  tabSwitchCount   Int           @default(0) @map("tab_switch_count")
  createdAt        DateTime      @default(now()) @map("created_at")

  student        User            @relation(fields: [studentId], references: [id])
  exam           Exam            @relation(fields: [examId], references: [id])
  studentAnswers StudentAnswer[]
  result         Result?

  @@map("exam_sessions")
}

model StudentAnswer {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  questionId     String   @map("question_id")
  selectedAnswer String?  @map("selected_answer") // "A"|"B"|"C"|"D" or null if skipped
  isCorrect      Boolean  @map("is_correct")
  createdAt      DateTime @default(now()) @map("created_at")

  session  ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@unique([sessionId, questionId])
  @@map("student_answers")
}

model Result {
  id               String   @id @default(uuid())
  sessionId        String   @unique @map("session_id")
  studentId        String   @map("student_id")
  examId           String   @map("exam_id")
  score            Float
  totalQuestions   Int      @map("total_questions")
  percentage       Float
  timeTakenSeconds Int      @map("time_taken_seconds")
  submittedAt      DateTime @map("submitted_at")
  createdAt        DateTime @default(now()) @map("created_at")

  session ExamSession @relation(fields: [sessionId], references: [id])
  student User        @relation(fields: [studentId], references: [id])
  exam    Exam        @relation(fields: [examId], references: [id])

  @@map("results")
}
